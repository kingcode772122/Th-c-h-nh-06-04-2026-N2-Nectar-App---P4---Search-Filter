@model List<baitap1.Models.SanPham>
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Products</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, Helvetica, sans-serif;
            background: #f5f5f5;
        }

        .tabs-wrapper {
            text-align: center;
            margin: 40px 0 30px;
        }

        .tabs {
            display: inline-flex;
            background: White;
        }

        .tab {
            padding: 10px 28px;
            color: #bbb;
            text-decoration: none;
            font-size: 14px;
            text-transform: uppercase;
        }

            .tab.active {
                background: #ff9800;
                color: #fff;
                font-weight: bold;
            }

        .container {
            width: 1200px;
            margin: auto;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 25px;
        }

        .item {
            background: #fff;
            padding: 15px;
            text-align: center;
            position: relative;
        }

            .item img {
                width: 100%;
                height: 170px;
                object-fit: contain;
            }

        .badge {
            position: absolute;
            top: 10px;
            left: 10px;
            padding: 4px 10px;
            font-size: 12px;
            color: #fff;
            border-radius: 3px;
        }

        .sale {
            background: #ff9800;
        }

        .sold {
            background: #ff4d4d;
        }

        .name {
            font-size: 13px;
            color: #777;
            margin-top: 10px;
        }

        .price {
            font-weight: bold;
            font-size: 14px;
            margin-top: 5px;
        }

        .old {
            color: #ff4d4d;
            font-size: 12px;
            text-decoration: line-through;
            margin-left: 5px;
        }

        .star {
            color: #f5c518;
            font-size: 13px;
            margin-top: 5px;
        }
    </style>
</head>

<body>

    <div class="tabs-wrapper">
        <div class="tabs">
            <a href="?tab=Latest" class="tab @(ViewBag.Tab == "Latest" ? "active" : "")">LATEST</a>
            <a href="?tab=Featured" class="tab @(ViewBag.Tab == "Featured" ? "active" : "")">FEATURED</a>
            <a href="?tab=Special" class="tab @(ViewBag.Tab == "Special" ? "active" : "")">SPECIAL</a>
        </div>
    </div>

    <div class="container">
        <div class="grid">
            @foreach (var sp in Model)
            {
                <div class="item">

                    @if (sp.SoldOut)
                    {
                        <div class="badge sold">SOLD OUT</div>
                    }
                    else if (sp.Sale)
                    {
                        <div class="badge sale">SALE</div>
                    }

                    <img src="@sp.Hinh" />

                    <div class="name">@sp.Ten</div>

                    <div class="price">
                        $@sp.Gia
                        @if (sp.GiaCu != null)
                        {
                            <span class="old">$@sp.GiaCu</span>
                        }
                    </div>

                    <div class="star">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span>@(i <= sp.Rating ? "★" : "☆")</span>
                        }
                    </div>

                </div>
            }
        </div>
    </div>

</body>
</html>
